@startuml System Architecture - Hotel Management Server

!define ICONURL https://raw.githubusercontent.com/tupadr3/plantuml-icon-font-sprites/v3.0.0/icons
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Inter
skinparam defaultFontSize 12
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 50

title **Hotel Management Server — System Architecture Diagram**\n NestJS + MySQL + AWS S3 + SMTP

' ─────────────────────────────────────────
' ACTORS
' ─────────────────────────────────────────
actor "Customer" as customer  #LightGreen
actor "Staff" as staff         #LightBlue
actor "Admin" as admin         #Salmon

' ─────────────────────────────────────────
' EXTERNAL SYSTEMS
' ─────────────────────────────────────────
cloud "SePay\n(Payment Gateway)" as sepay #LightYellow
cloud "AWS S3\n(Object Storage)" as s3 #Orange
cloud "SMTP Server\n(Gmail)" as smtp #LightCoral
database "MySQL Database\n(Aiven Cloud)" as mysqldb #LightSkyBlue

' ─────────────────────────────────────────
' NESTJS APPLICATION
' ─────────────────────────────────────────
package "NestJS Application (Port 8000)" as app {
  
  component "API Gateway & Security Layer\n(CORS, Throttler, Validation, JWT Auth, RBAC)" as gateway #AliceBlue

  package "Application Modules (Controllers & Services)" as modules #White {
    component "Auth & Users Module" as userMod #Honeydew
    component "Rooms & Services Module" as roomMod #Honeydew
    component "Booking Module" as bookingMod #Honeydew
    component "System Module\n(Reports, Logs, Uploads)" as sysMod #Honeydew
    component "Background Scheduler\n(Cron Jobs)" as cronMod #Lavender
  }

  component "Data Access Layer\n(Connection Pool, Transactions, SPs)" as dal #MistyRose
}

' ─────────────────────────────────────────
' RELATIONSHIPS
' ─────────────────────────────────────────
customer --> gateway : HTTPS Request
staff --> gateway : HTTPS Request
admin --> gateway : HTTPS Request
sepay --> gateway : Webhook Callback

gateway --> userMod
gateway --> roomMod
gateway --> bookingMod
gateway --> sysMod

userMod --> dal
roomMod --> dal
bookingMod --> dal
sysMod --> dal
cronMod --> dal

cronMod --> bookingMod : Trigger Auto-cancel\n& Reminders

bookingMod --> smtp : Send Notifications
sysMod --> s3 : Upload Media

dal ==> mysqldb : mysql2 Pool (TCP / TLS)

' ─────────────────────────────────────────
' LEGEND
' ─────────────────────────────────────────
legend right
  |= Color |= Meaning |
  | <#AliceBlue> | API Gateway & Security |
  | <#Honeydew> | Core Application Modules |
  | <#Lavender> | Background Processing |
  | <#MistyRose> | Data Access Layer |
  | <#LightSkyBlue> | External Database |
  | <#Orange> | Cloud Storage |
  | <#LightCoral> | Email Service |
  | <#LightYellow> | Payment Gateway |
endlegend

@enduml
